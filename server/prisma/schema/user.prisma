model User {
  id       String @id @default(uuid(4))
  username String
  email    String @unique
  password String

  watched  UserWatched[]
  friends  UserFriends[] @relation("UserFriends")
  friendOf UserFriends[] @relation("FriendOf")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}
